# HRMS Monolith Environment Variables

# Server Configuration
PORT=3000

# Database (Unified PostgreSQL)
DATABASE_URL="postgresql://hrms:hrms@localhost:5432/hrms_db?schema=public"

# Redis (For Session/BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Authentication
JWT_SECRET=dev-only-change-in-production-use-long-random-string
JWT_EXPIRES_IN=15m

# -----------------------------------------------------------------------------
# AWS ENTERPRISE CONFIGURATION (Required for Production S3 & SES)
# -----------------------------------------------------------------------------
# You will get these from your AWS IAM Console
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your_aws_access_key_here"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key_here"

# AWS S3 Configuration (For Hiring Resumes and Documents)
AWS_S3_BUCKET_NAME="hrms-production-resumes-bucket"

# AWS SES Configuration (For Email Delivery)
AWS_SES_SENDER_EMAIL="noreply@yourdomain.com"
