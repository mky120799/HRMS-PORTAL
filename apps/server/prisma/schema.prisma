generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  employees     Employee[]
  jobs          Job[]
  leaves        LeaveRequest[]
  notifications Notification[]
  attendance    AttendanceRecord[]
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         String   @default("ADMIN") // ADMIN, MANAGER, EMPLOYEE
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  employee Employee?

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Employee {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?  @unique
  email      String
  firstName  String
  lastName   String
  department String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id])
  user   User?          @relation(fields: [userId], references: [id])
  leaves LeaveRequest[]
  attendance AttendanceRecord[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model LeaveRequest {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  type       String // SICK, ANNUAL, CASUAL
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
}

model Job {
  id          String   @id @default(uuid())
  tenantId    String
  title       String
  description String
  department  String
  status      String   @default("OPEN") // OPEN, CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  applications Application[]

  @@index([tenantId])
}

model Application {
  id             String   @id @default(uuid())
  jobId          String
  candidateName  String
  candidateEmail String
  resumeUrl      String?
  resumeFilename String?
  status         String   @default("PENDING") // PENDING, INTERVIEW, HIRED, REJECTED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

model Notification {
  id              String   @id @default(uuid())
  tenantId        String
  channel         String // EMAIL, SMS, WHATSAPP
  title           String
  body            String
  status          String   @default("PENDING") // PENDING, SENT, FAILED
  recipientUserId String?
  recipientEmail  String?
  subject         String?
  metadata        Json?
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

model AttendanceRecord {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  date       DateTime @db.Date
  clockIn    DateTime
  clockOut   DateTime?
  status     String   @default("PRESENT") // PRESENT, HALF_DAY, ABSENT
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([tenantId])
}
